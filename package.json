{
  "name": "smart-report-engine",
  "version": "1.0.0",
  "description": "Smart Health Report Engine — Phase 1 Foundation",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run generate examples/indepth-report.json -- --pdf --no-cache --no-audit",
    "test:unit": "vitest run --exclude src/integration-tests/**",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:pdf": "vitest run --config vitest.pdf.config.ts",
    "test:all": "npm run test:unit && npm run test:e2e",
    "generate": "tsx src/cli/generate.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/sensible": "^6.0.4",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.2.2",
    "pino-pretty": "^13.1.3",
    "puppeteer": "^24.37.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
